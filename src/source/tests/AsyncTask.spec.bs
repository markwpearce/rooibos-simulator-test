namespace tests

  ' Plain (non-@SGNode) Task completion check: start a Task, poll its "result" field with
  ' assertAsyncField/wait() until it changes. Does not hang on either runtime, but the two
  ' disagree on the outcome: PASSes under brs-desktop, FAILs under brs-cli (see README
  ' finding "brs-cli vs brs-desktop disagree on plain Task field-sync completion").
  @suite
  class AsyncTaskTests extends tests.BaseTestSuite

    @describe("async task completion")

    @async(5000)
    @it("completes via assertAsyncField from a Task")
    sub _()
      task = createObject("roSGNode", "AsyncTask")
      m.task = task
      task.control = "run"
      m.assertAsyncField(m.task, "result", 1000)
      m.assertEqual(m.task.result, "done")
      m.done()
    end sub
  end class
end namespace
